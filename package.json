{
  "name": "tool-hub",
  "private": true,
  "version": "5.1.2",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "description": "Tool Hub — workspace tool catalog with GitHub health and local registry.",
  "author": "Tool Workspace",
  "scripts": {
    "dev": "node scripts/dev-with-launcher.cjs",
    "dev:vite": "vite --host 127.0.0.1 --port 5176",
    "dev:restart": "node scripts/kill-port.cjs 5176 && vite --host 127.0.0.1 --port 5176",
    "open": "node scripts/ensure-dev.cjs --open",
    "daemon:start": "node scripts/ensure-dev.cjs",
    "dev:clean": "node scripts/kill-port.cjs 5176 5178 && node -e \"require('fs').rmSync('node_modules/.vite',{recursive:true,force:true})\" && vite --host 127.0.0.1 --port 5176",
    "dev:recover": "node scripts/dev-recover.cjs",
    "dev:recover:open": "node scripts/dev-recover.cjs --open",
    "agent:manifest": "node scripts/sync-agent-manifest.mjs",
    "hub-ui:stack": "node ../scripts/hub-ui-stack.cjs",
    "build": "node scripts/build-supabase-quota-snapshot.mjs && node scripts/sync-agent-manifest.mjs && tsc --noEmit && vitest run --passWithNoTests && vite build",
    "lint": "eslint src",
    "deadcode": "knip --no-config-hints",
    "test": "vitest run && node --test scripts/lib/version-bump.test.cjs",
    "check:version": "node ../scripts/check-version-sync.mjs --product-root .",
    "test:watch": "vitest",
    "hooks:install": "node ../scripts/install-product-git-hooks.cjs --product-root .",
    "scan:local": "node scripts/scan-local-workspace.cjs",
    "sync:snapshots": "node ../scripts/sync-workspace-snapshots.cjs",
    "supabase:sync-vercel": "node ../scripts/supabase-sync-vercel.mjs",
    "supabase:apply-hub": "node scripts/apply-hub-migrations-all.mjs",
    "supabase:bundle-hub": "node scripts/bundle-hub-migrations.mjs",
    "supabase:verify-quota": "node scripts/verify-supabase-quota.mjs",
    "supabase:quota-snapshot": "node scripts/build-supabase-quota-snapshot.mjs",
    "sync:supabase-catalog": "node scripts/sync-supabase-catalog.cjs",
    "sync:workspace": "node scripts/sync-workspace-bidirectional.cjs",
    "sync:workspace:dry": "node scripts/sync-workspace-bidirectional.cjs --dry-run",
    "sync:workspace:clone": "node scripts/sync-workspace-bidirectional.cjs --clone-missing",
    "icons:sync": "node scripts/sync-thesvg-icons.cjs",
    "rules:sync": "node scripts/sync-rules-preview.cjs",
    "launcher": "node scripts/local-tool-launcher.cjs",
    "publish:github:init": "node scripts/publish-github-repo.cjs",
    "publish:github": "node scripts/publish-github-repo.cjs",
    "push": "powershell -ExecutionPolicy Bypass -File scripts/git-push.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 4176",
    "identity:phase0": "powershell -ExecutionPolicy Bypass -File scripts/identity-migration/apply-phase0.ps1",
    "identity:export": "node scripts/identity-migration/export-databox-identity.mjs",
    "identity:import:dry": "node scripts/identity-migration/import-hub-identity.mjs --dry-run",
    "identity:import": "node scripts/identity-migration/import-hub-identity.mjs",
    "identity:merge-users": "node scripts/identity-migration/merge-duplicate-hub-users.mjs",
    "identity:merge-users:dry": "node scripts/identity-migration/merge-duplicate-hub-users.mjs --dry-run",
    "identity:tool-access": "powershell -ExecutionPolicy Bypass -File scripts/apply-hub-tool-access.ps1",
    "identity:login-id": "node scripts/apply-hub-login-id.mjs"
  },
  "dependencies": {
    "@dev/hub-load": "file:./vendor/hub-load",
    "@tool-workspace/hub-identity": "file:./vendor/hub-identity",
    "@tool-workspace/hub-ui": "file:./vendor/hub-ui",
    "@supabase/supabase-js": "^2.106.2",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.451.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "10.4.20",
    "chrome-cookies-secure": "^3.0.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.4.0",
    "knip": "^5.50.0",
    "playwright": "1.50.1",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.6"
  }
}

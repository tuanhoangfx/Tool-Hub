{
  "name": "tool-hub",
  "private": true,
  "version": "0.1.8",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "description": "Tool Hub — workspace tool catalog with GitHub health and local registry.",
  "author": "Tool Workspace",
  "scripts": {
    "dev": "node scripts/kill-port.cjs 5176 && node scripts/dev-with-launcher.cjs",
    "dev:vite": "node scripts/kill-port.cjs 5176 && vite",
    "dev:clean": "node scripts/kill-port.cjs 5176 5178 && node -e \"require('fs').rmSync('node_modules/.vite',{recursive:true,force:true})\" && vite",
    "build": "tsc --noEmit && vitest run --passWithNoTests && vite build",
    "lint": "eslint src",
    "deadcode": "knip --no-config-hints",
    "test": "vitest run && node --test scripts/lib/version-bump.test.cjs",
    "test:watch": "vitest",
    "hooks:install": "node scripts/install-git-hooks.cjs",
    "scan:local": "node scripts/scan-local-workspace.cjs",
    "sync:workspace": "node scripts/sync-workspace-bidirectional.cjs",
    "sync:workspace:dry": "node scripts/sync-workspace-bidirectional.cjs --dry-run",
    "sync:workspace:clone": "node scripts/sync-workspace-bidirectional.cjs --clone-missing",
    "icons:sync": "node scripts/sync-thesvg-icons.cjs",
    "rules:sync": "node scripts/sync-rules-preview.cjs",
    "launcher": "node scripts/local-tool-launcher.cjs",
    "publish:github:init": "node scripts/publish-github-repo.cjs",
    "publish:github": "node scripts/publish-github-repo.cjs",
    "push": "powershell -ExecutionPolicy Bypass -File scripts/git-push.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 4176"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.451.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "10.4.20",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.4.0",
    "knip": "^5.50.0",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.6"
  }
}
